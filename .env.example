# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
GST_DESK_ENABLED="true"

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/jodo"
DIRECT_URL="postgresql://postgres:password@localhost:5432/jodo"

# Supabase Storage
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="jodo-files"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
CREDENTIALS_ENCRYPTION_KEY="replace-with-32-char-secret"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (magic links via SMTP)
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="JODO <noreply@jodo.in>"

# Resend (product emails + sequences)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="JODO <noreply@jodo.in>"

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# WhatsApp Business (Meta)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
META_WEBHOOK_VERIFY_TOKEN=""

# Meta / Instagram OAuth
META_APP_ID=""
META_APP_SECRET=""
META_OAUTH_SCOPES="pages_show_list,pages_manage_metadata,pages_read_engagement,instagram_manage_messages"

# Zoho OAuth + webhooks
ZOHO_CLIENT_ID=""
ZOHO_CLIENT_SECRET=""
ZOHO_ACCOUNTS_URL="https://accounts.zoho.in"
ZOHO_WEBHOOK_SECRET=""

# Queue Redis (BullMQ needs redis:// or rediss:// URL)
# Use either REDIS_URL or UPSTASH_REDIS_URL.
REDIS_URL=""
UPSTASH_REDIS_URL=""

# Queue tuning (optional)
WORKFLOW_QUEUE_NAME="workflow-execution"
WORKFLOW_DEAD_LETTER_QUEUE_NAME="workflow-dead-letter"
GST_EXTRACTION_QUEUE_NAME="gst-invoice-extraction"
WORKFLOW_QUEUE_CONCURRENCY="5"
WORKFLOW_QUEUE_ATTEMPTS="5"
WORKFLOW_QUEUE_BACKOFF_MS="5000"
WORKFLOW_QUEUE_REMOVE_ON_COMPLETE="500"
WORKFLOW_QUEUE_REMOVE_ON_FAIL="2000"
WORKFLOW_DEAD_LETTER_RETENTION="5000"
WORKFLOW_WORKER_HEARTBEAT_KEY="workflow-execution:worker:heartbeat"

# Monitoring
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""


SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="jodo-gst-documents"